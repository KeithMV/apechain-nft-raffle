# =============================================================================
# ENVIRONMENT CONFIGURATION EXAMPLE
# Copy this file to .env and fill in your actual values
# =============================================================================

# Development Server Configuration
DANGEROUSLY_DISABLE_HOST_CHECK=true
HOST=0.0.0.0
GENERATE_SOURCEMAP=true

# RPC Configuration
REACT_APP_ALCHEMY_API_KEY=your_alchemy_api_key_here
REACT_APP_APECHAIN_RPC_URL=https://apechain.calderachain.xyz/http

# Blockchain Configuration
REACT_APP_NETWORK=apechain
REACT_APP_CHAIN_ID=33139
REACT_APP_CONTRACT_ADDRESS=0xC9Bd344f5E31481F202E400C33210Bd1AB542b42

# WalletConnect
REACT_APP_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# App Configuration
REACT_APP_ENV=development
REACT_APP_APP_NAME=ApeChain NFT Raffles
REACT_APP_APP_URL=http://localhost:3000
REACT_APP_ENABLE_LOGGING=true