{
  "name": "@apechain/raffle-contracts",
  "version": "1.0.0",
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "test:coverage": "npx hardhat coverage",
    "deploy": "npx hardhat run scripts/deploy.js --network apechain",
    "deploy-secure": "npx hardhat run scripts/deploy-secure.js --network apechain",
    "deploy-secure-v2": "npx hardhat run scripts/deploy-secure-v2.js --network apechain",
    "verify-deployment": "npx hardhat run scripts/verify-secure-deployment.js --network apechain",
    "security-check": "npx hardhat run scripts/security-comparison.js",
    "security-validate-v2": "npx hardhat run scripts/security-validation-v2.js --network apechain",
    "verify": "npx hardhat verify --network apechain",
    "fee:status": "npx hardhat run scripts/fee-management.js --network apechain -- status",
    "fee:promotional": "npx hardhat run scripts/fee-management.js --network apechain -- promotional",
    "fee:competitive": "npx hardhat run scripts/fee-management.js --network apechain -- competitive",
    "fee:standard": "npx hardhat run scripts/fee-management.js --network apechain -- standard",
    "fee:premium": "npx hardhat run scripts/fee-management.js --network apechain -- premium",
    "fee:help": "npx hardhat run scripts/fee-management.js --network apechain -- --help"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "chai": "^4.5.0",
    "hardhat": "^2.28.4"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.6",
    "aws-sdk": "^2.1692.0",
    "dotenv": "^16.4.5",
    "ethers": "^5.8.0"
  }
}
