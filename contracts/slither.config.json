{
  "filter_paths": [
    "node_modules",
    "lib/forge-std",
    "@openzeppelin/contracts"
  ],
  "exclude_dependencies": true,
  "exclude_informational": false,
  "exclude_low": false,
  "exclude_medium": false,
  "exclude_high": false,
  "solc_remaps": [
    "@openzeppelin/contracts=node_modules/@openzeppelin/contracts"
  ],
  "detectors_to_exclude": [
    "pragma",
    "solc-version",
    "low-level-calls"
  ]
}