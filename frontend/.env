# =============================================================================
# STAGING ENVIRONMENT - LOCAL DEVELOPMENT
# =============================================================================
# Since you only use staging branch locally, this should be staging config

# Development Server Configuration
DANGEROUSLY_DISABLE_HOST_CHECK=true
HOST=0.0.0.0
GENERATE_SOURCEMAP=true
BROWSER=none

# =============================================================================
# BLOCKCHAIN CONFIGURATION
# =============================================================================

# Environment Detection - STAGING (not development)
REACT_APP_ENV=staging

# Network Configuration
REACT_APP_NETWORK=apechain
REACT_APP_CHAIN_ID=33139

# RPC Configuration
REACT_APP_APECHAIN_RPC_URL=https://apechain.calderachain.xyz/http

# Contract Address
REACT_APP_CONTRACT_ADDRESS=0x1627E7e63b63878E61f91D336385a59B1747934a

# =============================================================================
# WALLET CONFIGURATION
# =============================================================================

# WalletConnect Project ID
REACT_APP_WALLETCONNECT_PROJECT_ID=b848c907908cee0c1bcf0ab0493da6c4

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# App Metadata - LOCAL STAGING
REACT_APP_APP_NAME=ApeChain NFT Raffles (Local Staging)
REACT_APP_APP_URL=http://localhost:3000

# Logging
REACT_APP_ENABLE_LOGGING=true

# =============================================================================
# API CONFIGURATION
# =============================================================================
# Alchemy API Key - Use .env.local for local development
# REACT_APP_ALCHEMY_API_KEY should be set in .env.local (git-ignored)

# =============================================================================
# NOTES
# =============================================================================
# - This file is for LOCAL STAGING development (your primary workflow)
# - .env.staging is for REMOTE STAGING (CircleCI deployment)
# - .env.production is for PRODUCTION (main branch)
# - .env.local contains your personal API keys (git-ignored)