# =============================================================================
# ENVIRONMENT VARIABLES EXAMPLE
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# This file shows what environment variables are needed for development

# =============================================================================
# REQUIRED: API KEYS (Add to .env.local)
# =============================================================================

# Alchemy API Key (get from https://alchemy.com)
REACT_APP_ALCHEMY_API_KEY=your_alchemy_api_key_here

# WalletConnect Project ID (get from https://walletconnect.com)
REACT_APP_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# =============================================================================
# OPTIONAL: DEVELOPMENT SETTINGS (Add to .env.local if needed)
# =============================================================================

# Enable/disable console logging (true for debugging, false for clean console)
REACT_APP_ENABLE_LOGGING=true

# Development server settings
DANGEROUSLY_DISABLE_HOST_CHECK=true
HOST=0.0.0.0
GENERATE_SOURCEMAP=true
BROWSER=none

# =============================================================================
# AUTOMATIC: ENVIRONMENT DETECTION
# =============================================================================
# These are set automatically based on your environment:
# - Local development: Uses staging config with your .env.local secrets
# - Remote staging: Uses CircleCI environment variables
# - Production: Uses CircleCI environment variables

# You don't need to set these manually:
# REACT_APP_ENV=staging|production (auto-detected)
# REACT_APP_NETWORK=apechain (hardcoded)
# REACT_APP_CHAIN_ID=33139 (hardcoded)
# REACT_APP_CONTRACT_ADDRESS=0x1627E7e63b63878E61f91D336385a59B1747934a (hardcoded)
# REACT_APP_APECHAIN_RPC_URL=https://apechain.calderachain.xyz/http (hardcoded)

# =============================================================================
# SETUP INSTRUCTIONS:
# =============================================================================
# 1. Copy this file: cp .env.example .env.local
# 2. Edit .env.local and add your actual API keys
# 3. Run: yarn start:staging
# 4. Your app will use staging config with your personal API keys